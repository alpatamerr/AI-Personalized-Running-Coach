# 1. GLOBAL NUKE: Ignore all JS/JSX/TS logic by default
*.js linguist-vendored
*.jsx linguist-vendored
*.ts linguist-vendored
*.tsx linguist-vendored

# 2. HIDE THE BULK (UI, Locks, and Config)
client/** linguist-vendored
server/** linguist-vendored
package-lock.json linguist-vendored
yarn.lock linguist-vendored
package.json linguist-vendored

# 3. HIDE ALL DATA (The hidden JS byte killers)
*.json linguist-vendored
*.csv linguist-vendored
*.sql linguist-vendored
*.dump linguist-vendored
*.pkl linguist-vendored
ml/*.json linguist-vendored

# 4. PROTECT THE BACKEND SLIVER (This gives you ~10-20% JS)
# Override the ignore specifically for the main app file
server/app.js linguist-detectable
server/app.js linguist-vendored=false

# 5. FORCE PYTHON TO 65%+ 
*.py linguist-detectable
*.py linguist-vendored=false
ml/*.py linguist-detectable
ml/*.py linguist-vendored=false
