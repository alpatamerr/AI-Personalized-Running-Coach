# 1. Kill the 'Byte Monsters' (The files with thousands of lines)
client/** linguist-vendored
package-lock.json linguist-vendored
*.json linguist-vendored
*.dump linguist-vendored
*.csv linguist-vendored
*.sql linguist-vendored

# 2. Kill the 'UI Noise'
*.css linguist-vendored
*.html linguist-vendored
*.svg linguist-vendored

# 3. PROTECT ONLY THE BACKEND LOGIC (This provides your 30% JS)
# We do NOT ignore the server folder logic, only the server's data
server/plans/* linguist-vendored

# 4. FORCE PYTHON TO BE DETECTED FIRST
*.py linguist-detectable
ml/*.py linguist-detectable
