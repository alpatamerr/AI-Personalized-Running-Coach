# 1. NUKE THE UI AND LOCK FILES (The biggest sources of JS bytes)
client/* linguist-vendored
package-lock.json linguist-vendored
yarn.lock linguist-vendored

# 2. NUKE ALL DATA & DUMPS (Linguist thinks JSON/SQL is JS logic)
*.json linguist-vendored
*.csv linguist-vendored
*.sql linguist-vendored
*.dump linguist-vendored
*.pkl linguist-vendored
ml/*.json linguist-vendored
server/plans/* linguist-vendored

# 3. NUKE BACKEND UTILS (Keep the logic hidden, focus on ML)
server/utils/* linguist-vendored
server/config/* linguist-vendored
server/routes/* linguist-vendored

# 4. PROTECT THE CORE SLIVER (This gives you ~10-20% JS)
# We only let the main app and controllers be detected
server/app.js linguist-detectable
server/controllers/* linguist-detectable

# 5. FORCE PYTHON TO THE FRONT
*.py linguist-detectable
ml/*.py linguist-detectable
import_training_records.py linguist-detectable
